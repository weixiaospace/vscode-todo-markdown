{
  "name": "keyan-vscode-todo",
  "displayName": "Todo (Markdown)",
  "description": "%ext.description%",
  "version": "0.1.0",
  "private": true,
  "publisher": "keyan",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "main": "./out/extension.js",
  "l10n": "./l10n",
  "activationEvents": [
    "onStartupFinished"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "todoMd",
          "title": "%activitybar.title%",
          "icon": "$(checklist)"
        }
      ]
    },
    "views": {
      "todoMd": [
        {
          "id": "todoMd.tree",
          "name": "TODO.md",
          "contextualTitle": "%view.contextualTitle%"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "todoMd.tree",
        "contents": "%welcome.noWorkspace%",
        "when": "!workbenchState || workbenchState == 'empty'"
      },
      {
        "view": "todoMd.tree",
        "contents": "%welcome.noFile%",
        "when": "workbenchState != 'empty' && todoMd.fileMissing"
      }
    ],
    "commands": [
      { "command": "todoMd.refresh",      "title": "%cmd.refresh.title%",      "icon": "$(refresh)" },
      { "command": "todoMd.openFile",     "title": "%cmd.openFile.title%",     "icon": "$(go-to-file)" },
      { "command": "todoMd.openSettings", "title": "%cmd.openSettings.title%", "icon": "$(settings-gear)" },
      { "command": "todoMd.createFile",   "title": "%cmd.createFile.title%" },
      { "command": "todoMd.reveal",       "title": "%cmd.reveal.title%" },
      { "command": "todoMd.toggle",       "title": "%cmd.toggle.title%",       "icon": "$(check)" },
      { "command": "todoMd.reopen",       "title": "%cmd.reopen.title%",       "icon": "$(circle-slash)" }
    ],
    "menus": {
      "view/title": [
        { "command": "todoMd.refresh",      "when": "view == todoMd.tree", "group": "navigation@1" },
        { "command": "todoMd.openFile",     "when": "view == todoMd.tree", "group": "navigation@2" },
        { "command": "todoMd.openSettings", "when": "view == todoMd.tree", "group": "navigation@3" }
      ],
      "view/item/context": [
        { "command": "todoMd.toggle", "when": "view == todoMd.tree && viewItem == todoItemPending", "group": "inline" },
        { "command": "todoMd.reopen", "when": "view == todoMd.tree && viewItem == todoItemDone",    "group": "inline" }
      ],
      "commandPalette": [
        { "command": "todoMd.reveal", "when": "false" },
        { "command": "todoMd.toggle", "when": "false" },
        { "command": "todoMd.reopen", "when": "false" }
      ]
    },
    "configuration": {
      "title": "%config.title%",
      "properties": {
        "todoMd.file": {
          "type": "string",
          "default": "TODO.md",
          "description": "%config.file.description%"
        },
        "todoMd.collapsedSections": {
          "type": "array",
          "items": { "type": "string" },
          "default": ["已决定不做", "最近完成", "已完成"],
          "description": "%config.collapsedSections.description%"
        },
        "todoMd.maxFileSizeKb": {
          "type": "number",
          "default": 1024,
          "description": "%config.maxFileSizeKb.description%"
        },
        "todoMd.showDoneDescription": {
          "type": "boolean",
          "default": true,
          "description": "%config.showDoneDescription.description%"
        },
        "todoMd.hideEmptyGroups": {
          "type": "string",
          "enum": ["never", "noItems", "noPending"],
          "enumDescriptions": [
            "%config.hideEmptyGroups.never%",
            "%config.hideEmptyGroups.noItems%",
            "%config.hideEmptyGroups.noPending%"
          ],
          "default": "noItems",
          "description": "%config.hideEmptyGroups.description%"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs --production",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.2.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.4.0",
    "vitest": "^2.1.0"
  }
}
